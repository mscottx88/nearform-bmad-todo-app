# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=todo_pond
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/todo_pond

# Google API (for embeddings)
GOOGLE_API_KEY=your-google-api-key-here
EMBEDDING_MODEL=models/text-embedding-004

# Anthropic API key (for AI agent chat — Epic 6)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# CORS
CORS_ORIGINS=http://localhost:5173

# Archive
ARCHIVE_THRESHOLD_DAYS=30

# Frontend — defaults to `/api` (Vite proxies to backend). Only set to override
# for deployed environments. Avoid `/api` here: on Git Bash/MSYS for Windows the
# leading slash is mangled into `C:/Program Files/Git/api`, which breaks the app.
# If overriding locally, use an absolute URL (e.g. https://api.example.com) or
# put the value in `frontend/.env.local` (Vite reads it without shell munging).
